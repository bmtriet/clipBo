{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KoDauKoVui",
  "version": "0.1.0",
  "identifier": "com.kodaukovui.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "KoDauKoVui",
        "label": "main",
        "width": 920,
        "height": 680,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "url": "index.html?page=settings"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
