# AI provider
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_token_here
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Hotkeys
HOTKEY=<ctrl>+<shift>+1
HOTKEY_TRANS_EN=<ctrl>+<shift>+@
HOTKEY_TRANS_ZHTW=<ctrl>+<shift>+#
HOTKEY_TRANS_KHMER=<ctrl>+<shift>+$
HOTKEY_TRANS_VI=<ctrl>+<f5>
HOTKEY_QA=<ctrl>+<f12>
HOTKEY_POPUP=<ctrl>+/

# UI / behavior
UI_LANGUAGE=en
KEEP_ORIGINAL_TEXT=false
SHOW_QUESTION_IN_QA=false
DEBUG=false
